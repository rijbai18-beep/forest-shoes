# Forest Shoes Test Environment
# Copy this file to .env.test and fill in real values.
# NEVER commit .env.test to git.

# ── Mobile app test credentials ───────────────────────────────────────────────
# A real Firebase test account (not admin) that has placed at least one order.
TEST_EMAIL=testuser@forestshoes.com
TEST_PASSWORD=Test@1234

# ── Web admin credentials ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@forestshoes.com
ADMIN_PASSWORD=Admin@1234

# ── URLs (defaults work for local dev) ────────────────────────────────────────
WEB_ADMIN_URL=http://localhost:3000

# ── Android device / simulator ───────────────────────────────────────────────
# Run `flutter devices` to find your device ID
ANDROID_DEVICE_ID=emulator-5554

# ── iOS simulator (Mac only) ─────────────────────────────────────────────────
# Run `xcrun simctl list devices` to find your simulator UDID
IOS_DEVICE_ID=
